<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:background="#F6F7FB"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:padding="20dp"
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <TextView
            android:text="Today's Exercise"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="#111827"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <TextView
            android:text="Stay fit and complete your workout"
            android:textColor="#6B7280"
            android:layout_marginBottom="20dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <!-- Exercise Card -->
        <LinearLayout
            android:background="#FFFFFF"
            android:elevation="4dp"
            android:padding="16dp"
            android:orientation="vertical"
            android:layout_marginBottom="16dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <TextView
                android:id="@+id/tvExerciseName"
                android:text="Push Ups"
                android:textSize="20sp"
                android:textStyle="bold"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <TextView
                android:id="@+id/tvExerciseInfo"
                android:text="3 Sets • 15 Reps"
                android:textColor="#6B7280"
                android:layout_marginTop="4dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <TextView
                android:id="@+id/tvCaloriesBurn"
                android:text="🔥 Estimated Burn: 40 kcal"
                android:layout_marginTop="6dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

        </LinearLayout>
        <!-- Squats Card -->
        <LinearLayout
            android:background="#FFFFFF"
            android:elevation="4dp"
            android:padding="16dp"
            android:orientation="vertical"
            android:layout_marginBottom="16dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <TextView
                android:text="Squats"
                android:textSize="20sp"
                android:textStyle="bold"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <TextView
                android:text="3 Sets • 20 Reps"
                android:textColor="#6B7280"
                android:layout_marginTop="4dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <TextView
                android:text="🔥 Estimated Burn: 50 kcal"
                android:layout_marginTop="6dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

        </LinearLayout>

        <!-- Plank Card -->
        <LinearLayout
            android:background="#FFFFFF"
            android:elevation="4dp"
            android:padding="16dp"
            android:orientation="vertical"
            android:layout_marginBottom="16dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <TextView
                android:text="Plank"
                android:textSize="20sp"
                android:textStyle="bold"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <TextView
                android:text="Hold for 30 seconds"
                android:textColor="#6B7280"
                android:layout_marginTop="4dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <TextView
                android:text="🔥 Estimated Burn: 30 kcal"
                android:layout_marginTop="6dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

        </LinearLayout>

        <!-- Timer -->
        <TextView
            android:id="@+id/tvTimer"
            android:text="00 : 60"
            android:textSize="36sp"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginTop="20dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>

        <!-- Start Button -->
        <Button
            android:id="@+id/btnStartWorkout"
            android:text="START WORKOUT"
            android:textAllCaps="false"
            android:textSize="18sp"
            android:layout_marginTop="20dp"
            android:backgroundTint="#22C55E"
            android:textColor="#FFFFFF"
            android:layout_width="match_parent"
            android:layout_height="55dp"/>
        <TextView
            android:id="@+id/tvCurrentExercise"
            android:text="Push Ups"
            android:textSize="28sp"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginTop="20dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>
        <ProgressBar
            android:id="@+id/workoutProgress"
            style="?android:attr/progressBarStyleHorizontal"
            android:max="3"
            android:progress="1"
            android:layout_marginTop="20dp"
            android:layout_width="match_parent"
            android:layout_height="10dp"/>

    </LinearLayout>

</ScrollView>