<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:background="#F3F7FF"
    android:padding="18dp"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- HEADER -->
        <LinearLayout
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="12dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <ImageView
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/img_25"
                android:layout_marginEnd="10dp"/>

            <TextView
                android:text="AI Symptom Checker"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="#0F172A"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
        </LinearLayout>

        <TextView
            android:text="Describe your symptoms and our AI will help analyze them."
            android:textSize="14sp"
            android:textColor="#64748B"
            android:layout_marginBottom="18dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>


        <!-- AGE INPUT -->
        <LinearLayout
            android:background="@drawable/input_card"
            android:padding="12dp"
            android:layout_marginBottom="10dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/img_21"
                android:layout_marginEnd="8dp"/>

            <EditText
                android:id="@+id/etAge"
                android:hint="Age"
                android:textColor="@color/black"
                android:background="@android:color/transparent"
                android:inputType="number"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>
        </LinearLayout>


        <!-- TEMPERATURE -->
        <LinearLayout
            android:background="@drawable/input_card"
            android:padding="12dp"
            android:layout_marginBottom="10dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/img_22"
                android:layout_marginEnd="8dp"/>

            <EditText
                android:id="@+id/etTemp"
                android:hint="Body Temperature (°C)"
                android:textColor="@color/black"
                android:background="@android:color/transparent"
                android:inputType="numberDecimal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>
        </LinearLayout>


        <!-- SYMPTOMS -->
        <LinearLayout
            android:background="@drawable/input_card"
            android:padding="12dp"
            android:layout_marginBottom="10dp"
            android:orientation="horizontal"
            android:gravity="top"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/img_23"
                android:layout_marginEnd="8dp"/>

            <EditText
                android:id="@+id/etSymptoms"
                android:textColor="@color/black"
                android:hint="Describe symptoms (fever, cough, headache...)"
                android:background="@android:color/transparent"
                android:minLines="3"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>
        </LinearLayout>


        <!-- CHECK BUTTON -->
        <Button
            android:id="@+id/btnCheck"
            android:text="Analyze Symptoms"
            android:textAllCaps="false"
            android:textSize="16sp"
            android:textStyle="bold"
            android:backgroundTint="#DEB887"
            android:textColor="#FFFFFF"
            android:layout_marginTop="6dp"
            android:layout_width="match_parent"
            android:layout_height="50dp"/>


        <!-- RESULT CARD -->
        <LinearLayout
            android:orientation="vertical"
            android:background="@drawable/result_card"
            android:padding="14dp"
            android:layout_marginTop="18dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <TextView
                android:text="AI Result"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#0F172A"
                android:layout_marginBottom="6dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <TextView
                android:id="@+id/tvResult"
                android:text="AI response will appear here..."
                android:textSize="15sp"
                android:textColor="#334155"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>

        </LinearLayout>


        <!-- HEALTH TIP -->
        <LinearLayout
            android:orientation="horizontal"
            android:background="@drawable/tip_card"
            android:padding="12dp"
            android:layout_marginTop="16dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <ImageView
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:src="@drawable/img_24"
                android:layout_marginEnd="8dp"/>

            <TextView
                android:text="Tip: Drink plenty of water and rest if you feel feverish."
                android:textSize="14sp"
                android:textColor="#065F46"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
        </LinearLayout>

    </LinearLayout>

</ScrollView>