<?xml version="1.0" encoding="utf-8"?>

<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#8BB0F6">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- HEADER IMAGE -->
        <ImageView
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:layout_gravity="center"
            android:src="@drawable/img_13"
            android:layout_marginTop="20dp"
            android:contentDescription="medicine"/>

        <!-- TITLE -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Medicine Reminder"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="#274B64"
            android:layout_gravity="center"
            android:layout_marginTop="12dp"/>

        <!-- SUBTITLE -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Stay healthy, never miss a dose 💙"
            android:textSize="14sp"
            android:textColor="#6B7280"
            android:layout_gravity="center"
            android:layout_marginBottom="20dp"/>

        <!-- CARD -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/card_white1"
            android:orientation="vertical"
            android:padding="20dp"
            android:elevation="6dp">

            <!-- MEDICINE NAME -->
            <TextView
                android:text="Medicine Name"
                android:textStyle="bold"
                android:textColor="#374151"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <EditText
                android:id="@+id/etMedicineName"
                android:hint="Example: Paracetamol"
                android:textColor="@color/black"
                android:background="@drawable/rounded_edittext1"
                android:padding="12dp"
                android:layout_marginTop="6dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>

            <!-- TIME BUTTON -->
            <Button
                android:id="@+id/btnPickTime"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="⏰ Select Reminder Time"
                android:textColor="#FFFFFF"
                android:backgroundTint="#22C55E"
                android:layout_marginTop="16dp"
                android:padding="12dp"/>

            <!-- SELECTED TIME -->
            <TextView
                android:id="@+id/tvSelectedTime"
                android:text="No time selected"
                android:textColor="#6B7280"
                android:textSize="14sp"
                android:layout_marginTop="10dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <!-- SAVE BUTTON -->
            <Button
                android:id="@+id/btnSaveReminder"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Save Reminder 💊"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:backgroundTint="#9560F4"
                android:layout_marginTop="20dp"
                android:padding="14dp"/>

        </LinearLayout>

        <!-- QUOTE -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="“A healthy outside starts from the inside.”"
            android:textStyle="italic"
            android:textColor="#0E2DD7"
            android:gravity="center"
            android:layout_marginTop="24dp"/>

    </LinearLayout>

</ScrollView>