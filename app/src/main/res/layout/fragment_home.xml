<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    android:background="#F2F6FF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- GREETING -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Welcome 👋"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#1F2937"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Here’s your health summary."
            android:textSize="14sp"
            android:textColor="#6B7280"
            android:layout_marginBottom="10dp"/>

        <!-- STATS GRID -->
        <GridLayout
            android:columnCount="2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <!-- STEPS CARD -->
            <LinearLayout
                android:id="@+id/cardSteps"
                android:layout_width="0dp"
                android:layout_height="150dp"
                android:layout_columnWeight="1"
                android:background="@drawable/card_blue"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_margin="6dp"
                android:padding="10dp">

                <TextView
                    android:layout_height="wrap_content"
                    android:layout_width="wrap_content"
                    android:text="Steps"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:textStyle="bold"/>

                <FrameLayout
                    android:layout_width="90dp"
                    android:layout_height="90dp"
                    android:layout_marginTop="6dp">

                    <!-- Circular progress -->
                    <ProgressBar
                        android:id="@+id/stepProgress"
                        style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:progressDrawable="@drawable/circular_progress"
                        android:max="100"
                        android:progress="0"/>

                    <!-- Steps text in center -->
                    <TextView
                        android:id="@+id/tvSteps"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textColor="#FFFFFF"
                        android:textStyle="bold"
                        android:textSize="18sp"
                        android:layout_gravity="center"/>

                </FrameLayout>

                <TextView
                    android:id="@+id/tvStepGoal"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Goal: 10,000"
                    android:textColor="#E5E7EB"
                    android:layout_marginTop="-1dp"/>

            </LinearLayout>


            <!-- WATER INTAKE CARD -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="147dp"
                android:layout_columnWeight="1"
                android:background="@drawable/card_white"
                android:elevation="4dp"
                android:orientation="vertical"
                android:layout_margin="6dp"
                android:padding="14dp">

                <!-- HEADER ROW -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <ImageView
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:src="@drawable/img_10"
                        />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Water Intake"
                        android:textStyle="bold"
                        android:textSize="14sp"
                        android:textColor="#1F2937"
                        android:layout_marginStart="8dp"/>
                </LinearLayout>

                <!-- WATER COUNT -->
                <TextView
                    android:id="@+id/tvWater"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0 / 8 "
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:textColor="#0F172A"
                    android:layout_marginTop="10dp"
                    android:clickable="true"
                    android:focusable="true"/>

                <!-- HINT -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Tap or Long Press"
                    android:textSize="12sp"
                    android:textColor="#9CA3AF"/>

                <!-- BUTTON -->
                <Button
                    android:id="@+id/btnAddWater"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:text="+ Drink"
                    android:textAllCaps="false"
                    android:textSize="12sp"
                    android:backgroundTint="#06B6D4"
                    android:textColor="#FFFFFF"
                    />

            </LinearLayout>

            <!-- SLEEP CARD -->
            <!-- BMI CARD -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="120dp"
                android:layout_columnWeight="1"
                android:background="@drawable/card_green"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_margin="6dp"
                android:padding="10dp">

                <ImageView
                    android:layout_width="30dp"
                    android:layout_height="30dp"
                    android:src="@drawable/img_14"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="BMI"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"/>

                <TextView
                    android:id="@+id/tvBMI"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="22.0"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"/>

                <TextView
                    android:id="@+id/tvBMICategory"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Healthy"
                    android:textColor="#E5E7EB"/>
            </LinearLayout>
            <!-- CALORIES CARD -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="120dp"
                android:layout_columnWeight="1"
                android:background="@drawable/card_orange"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_margin="6dp"
                android:padding="10dp">

                <ImageView
                    android:layout_width="30dp"
                    android:layout_height="30dp"
                    android:src="@drawable/img_11"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Calories"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="520 kcal"
                    android:id="@+id/tvCalories"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Burned"
                    android:textColor="#E5E7EB"/>
            </LinearLayout>

        </GridLayout>

        <!-- QUICK ACTIONS ROW -->
        <!-- QUICK ACTION ICON CARDS (EXACT LIKE IMAGE) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="4"
            android:layout_marginTop="12dp">

            <!-- AI CHATBOT CARD -->
            <LinearLayout
                android:id="@+id/cardAiChat"
                android:layout_width="0dp"
                android:layout_height="110dp"
                android:layout_weight="1"
                android:background="#EAEB2222"
                android:orientation="vertical"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true"
                android:layout_margin="6dp"
                android:padding="8dp">

                <ImageView
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:src="@drawable/img_6"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Medical AI "
                    android:textColor="#E9E4E4"
                    android:textStyle="bold"
                    android:textSize="13sp"
                    android:layout_marginTop="6dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Ask AI"
                    android:textSize="12sp"
                    android:textStyle="italic"
                    android:textColor="#E9E4E4"/>
            </LinearLayout>

            <!-- DIET PLAN CARD -->
            <LinearLayout
                android:id="@+id/cardDietPlan"
                android:layout_width="0dp"
                android:layout_height="110dp"
                android:layout_weight="1"
                android:background="#9DEF56"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_margin="6dp"
                android:padding="8dp">

                <ImageView
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:src="@drawable/img_3"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Diet Plan"
                    android:textStyle="bold"
                    android:textSize="13sp"
                    android:layout_marginTop="6dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Meal Plan"
                    android:textSize="12sp"
                    android:textColor="#555555"/>
            </LinearLayout>

            <!-- WORKOUT CARD -->
            <LinearLayout
                android:id="@+id/cardWorkout"
                android:layout_width="0dp"
                android:layout_height="110dp"
                android:layout_weight="1"
                android:background="#F2D769"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_margin="6dp"
                android:padding="8dp">

                <ImageView
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:src="@drawable/img_4"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Workout"
                    android:textStyle="bold"
                    android:textSize="13sp"
                    android:layout_marginTop="6dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Exercise"
                    android:textSize="12sp"
                    android:textColor="#555555"/>
            </LinearLayout>

            <!-- REMINDERS CARD -->
            <LinearLayout
                android:id="@+id/cardReminder"
                android:layout_width="0dp"
                android:layout_height="110dp"
                android:layout_weight="1"
                android:background="#F2F676FD"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_margin="6dp"
                android:padding="8dp">

                <ImageView
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:src="@drawable/img_5"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Reminders"
                    android:textStyle="bold"
                    android:textSize="13sp"
                    android:layout_marginTop="6dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Medicines"
                    android:textSize="12sp"
                    android:textColor="#000"/>
            </LinearLayout>

        </LinearLayout>



        <!-- WEEKLY REPORT CARD -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/card_white"
            android:orientation="horizontal"
            android:padding="14dp"
            android:gravity="center_vertical"
            android:layout_marginTop="12dp">

            <ImageView
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:src="@drawable/img_8"
                android:padding="10dp"/>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_weight="1"
                android:layout_marginStart="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Weekly Health Report"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="#1F2937"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Track your weekly fitness summary"
                    android:textSize="13sp"
                    android:textColor="#6B7280"/>
            </LinearLayout>

            <Button
                android:id="@+id/btnShowWeeklyReport"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:text="View"
                android:textAllCaps="false"
                android:backgroundTint="#22C55E"
                android:textColor="#FFFFFF"/>
        </LinearLayout>


        <!-- FIND HOSPITALS CARD -->
        <!-- FIND HOSPITAL CARD -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/card_white"
            android:orientation="horizontal"
            android:padding="14dp"
            android:gravity="center_vertical"
            android:layout_marginTop="12dp">

            <ImageView
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:src="@drawable/img_7"
                android:padding="10dp"/>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_weight="1"
                android:layout_marginStart="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Nearby Hospitals"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="#1F2937"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Get emergency medical help nearby"
                    android:textSize="13sp"
                    android:textColor="#6B7280"/>
            </LinearLayout>

            <Button
                android:id="@+id/btnFindHospital"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:text="Open"
                android:textAllCaps="false"
                android:backgroundTint="#49D5C8"
                android:textColor="#FFFFFF"/>
        </LinearLayout>

    </LinearLayout>
</ScrollView>